---
interface Props {
  siteName?: string;
}

const { siteName = 'McHugh Analytics' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-800 text-neutral-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm">
        &copy; {currentYear} {siteName}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-sm hover:text-white transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-sm hover:text-white transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
