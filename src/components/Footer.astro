---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-900 text-primary-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-3 hover:opacity-80 transition-opacity w-fit">
          <img src="/mchughanalytics.png" alt="McHugh Analytics" class="h-8 w-auto brightness-150" />
          <span class="font-semibold text-white text-sm tracking-tight">McHugh Analytics</span>
        </a>
        <p class="text-sm text-primary-400 max-w-xs leading-relaxed">
          AI agents and cloud infrastructure consulting for growing businesses. Senior engineering, no agency overhead.
        </p>
      </div>
      <!-- Links -->
      <div>
        <p class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Navigation</p>
        <ul class="space-y-2">
          <li><a href="/services" class="text-sm hover:text-white transition-colors">Services</a></li>
          <li><a href="/about" class="text-sm hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm hover:text-white transition-colors">Contact</a></li>
          <li><a href="/privacy" class="text-sm hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-primary-800 pt-6">
      <p class="text-xs text-primary-500">
        &copy; {currentYear} McHugh Analytics. All rights reserved.
      </p>
    </div>
  </div>
</footer>
