---
interface Props {
  title: string;
  description?: string;
  href?: string;
}

const { title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block bg-white rounded-xl border border-neutral-200 p-6 transition-all',
    href && 'hover:border-accent-400 hover:shadow-lg cursor-pointer',
  ]}
>
  <h3 class="text-lg font-semibold text-neutral-900 mb-2 group-hover:text-accent-700 transition-colors">
    {title}
  </h3>
  {description && (
    <p class="text-neutral-600 text-sm leading-relaxed mb-4">{description}</p>
  )}
  <slot />
  {href && (
    <span class="inline-flex items-center gap-1 text-accent-600 text-sm font-medium mt-auto">
      Learn more
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </span>
  )}
</Tag>
