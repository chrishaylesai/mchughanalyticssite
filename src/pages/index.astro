---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/Card.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title="McHugh Analytics" description="Data-driven insights for your business">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-800 via-primary-600 to-accent-500 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6">
          McHugh Analytics
        </h1>
        <p class="text-lg sm:text-xl text-primary-100 mb-8">
          Placeholder hero text. Describe your value proposition here.
        </p>
        <a
          href="/contact"
          class="inline-block bg-white text-primary-800 px-6 py-3 rounded-lg font-semibold hover:bg-accent-50 transition-colors"
        >
          Get Started
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-8 text-center">
        Services
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <Card
            title={service.data.title}
            description={service.data.description}
            href={`/services/${service.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-neutral-100 py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-4">
        Ready to get started?
      </h2>
      <p class="text-neutral-600 mb-8 max-w-2xl mx-auto">
        Placeholder call-to-action text. Encourage visitors to take the next step.
      </p>
      <a
        href="/contact"
        class="inline-block bg-accent-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-accent-600 transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</PageLayout>
